# MinerU PDF / 文档解析后端配置
# 复制本文件为 .env 并填入真实值后启用
# .env 不会被 git 跟踪（已在 .gitignore 中忽略）

# MinerU Cloud API Token（从 https://mineru.net/apiManage 获取）
# 留空则无法使用 Cloud 后端，本地 PDF 会尝试回退到 MinerU Local
MINERU_API_TOKEN=

# MinerU Local Python 解释器（敏感 PDF 本地解析用）
# 默认指向已安装 MinerU 的独立 venv，一般不需要修改
MINERU_PYTHON_EXE=<home>/.workbuddy/binaries/python/envs/mineru/Scripts/python.exe

# 强制所有 PDF 走本地 MinerU（非交互模式下的敏感文档开关）
# 设为 1 表示敏感（走 local），0 或不设表示非敏感（走 cloud）
MINERU_PDF_SENSITIVE=0
