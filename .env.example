# ============================================================
# obsidian_wiki_skill 配置
# 复制本文件为 .env 并填入真实值。.env 已被 .gitignore 排除，不会入库。
#
# 加载机制：scripts/_config.py 在所有入口脚本（build_index.py / query.py /
# build_graph.py / update_wiki.py / picture_caption.py）顶部被 import，
# 会自动加载本文件到环境变量。无需在每个脚本单独配置。
#
# 配置分层原则（不是所有路径都该写在这里）：
#   - <skill_dir>：脚本自推导（Path(__file__)），不需要配置。
#   - <project_root>：每次调用可能不同，是命令行第一个参数，不放这里。
#   - 以下变量：每台机器装一次就不变的"环境级"配置，适合写 .env。
# ============================================================

# --- 核心检索（可选，均有回退）---

# embedding 模型本地路径。留空则按以下顺序探测：
#   1. ~/.workbuddy/binaries/python/envs/default/models/paraphrase-multilingual-MiniLM-L12-v2
#   2. HuggingFace 在线下载（受下方 HF_ENDPOINT 影响）
# Windows 示例: C:/path/to/venv/models/paraphrase-multilingual-MiniLM-L12-v2
WIKI_EMBEDDER_LOCAL_PATH=

# HuggingFace 端点。中国大陆网络建议保留镜像；海外网络可留空使用官方源。
HF_ENDPOINT=https://hf-mirror.com

# --- MinerU Cloud（非敏感文档解析后端，默认路由，需联网）---

# 必填（若要解析 pdf/doc/ppt/xls/html）。从 https://mineru.net/apiManage 获取。
# 留空则无法使用 Cloud 后端；标记为敏感的文档会转而尝试 MinerU Local。
MINERU_API_TOKEN=

# --- MinerU Local（可选组件，仅处理敏感文档，数据不出本机）---
# 与 MinerU Cloud 是互斥的两条路径：非敏感文档永远不会用到以下配置。

# MinerU Local 独立 venv 的 python 可执行文件。
# 留空时脚本会按约定位置自动探测（WorkBuddy 用户常见安装路径）：
#   Windows: ~/.workbuddy/binaries/python/envs/mineru/Scripts/python.exe
#   Linux/macOS: ~/.workbuddy/binaries/python/envs/mineru/bin/python
# 探测不到才会抛错并提示安装步骤（见 README.md > MinerU Local）。
# 若你的 MinerU venv 装在别处，显式填写以下路径覆盖自动探测：
# Windows 示例: C:/path/to/mineru_venv/Scripts/python.exe
# Linux/macOS 示例: /path/to/mineru_venv/bin/python
MINERU_PYTHON_EXE=

# MinerU 自身的模型配置文件路径（可选，透传给 MinerU 子进程）。
# 这是 MinerU 官方环境变量，本 skill 不解析它，只是把它转发给子进程。
# 每个人下载的模型存放路径不同（硬盘大小/挂载盘不同），因此模型路径本身
# 不由本 skill 管理，而是写在 MinerU 自己的配置文件（默认 ~/mineru.json）里：
#   { "models-dir": { "pipeline": "/your/path", "vlm": "/your/path" } }
# 若你的 mineru.json 不在默认位置（~/mineru.json），在此指定实际路径：
# MINERU_TOOLS_CONFIG_JSON=C:/path/to/mineru.json
MINERU_TOOLS_CONFIG_JSON=

# 非交互模式下的敏感文档强制开关：1=所有 PDF/PPTX 走 Local，0/留空=走 Cloud
MINERU_PDF_SENSITIVE=0
